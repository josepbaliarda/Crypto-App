{
  "expo": {
    "name": "CryptoApp",
    "slug": "crypto-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "crypto-app",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0052FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cryptoapp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0052FF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.cryptoapp.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Allow CryptoApp to access your camera for QR code scanning" }
      ],
      [
        "expo-local-authentication",
        { "faceIDPermission": "Allow CryptoApp to use Face ID for secure authentication" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001",
      "ethereumNetwork": "sepolia"
    }
  }
}
